// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type Player {
  id       String?
  nickname String
  clanId   String?
}

type Stat {
  kill    Int
  death   Int
  assists Int
  matchId String
}

model User {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  discordId String?
  name      String?
  email     String? @unique
  birthDate String?

  emailVerified DateTime?
  isOnboarded   Boolean   @default(false)

  image String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player       Player?
  generalStats Stat[]

  accounts               Account[]
  sessions               Session[]
  tournaments            Tournament[]
  participants           Participant[]
  requestTournamentRoles TournamentRoleRequest[]
}

model Account {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId

  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?

  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Team {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tournamentId String @db.ObjectId

  name String?
  seed Int?
  side TeamSide @default(CT)

  tournament Tournament   @relation(fields: [tournamentId], references: [id])
  members    TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchesAsTeam1      Match[] @relation("Team1")
  matchesAsTeam2      Match[] @relation("Team2")
  matchesAsWinnerTeam Match[] @relation("WinnerTeam")
}

enum TeamSide {
  TR
  CT
}

model TeamMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  teamId        String @db.ObjectId
  participantId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id])
}

model Match {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tournamentId String @db.ObjectId
  roundId      String @db.ObjectId

  team1Id String? @db.ObjectId
  team2Id String? @db.ObjectId

  winnerTeamId String? @db.ObjectId

  status MatchStatus @default(WAITING)

  nextMatchId   String?    @db.ObjectId
  nextMatchSlot MatchSlot?

  team1      Team? @relation("Team1", fields: [team1Id], references: [id])
  team2      Team? @relation("Team2", fields: [team2Id], references: [id])
  winnerTeam Team? @relation("WinnerTeam", fields: [winnerTeamId], references: [id])

  round      Round      @relation(fields: [roundId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MatchSlot {
  TEAM1
  TEAM2
}

enum MatchStatus {
  WAITING
  READY
  CONFIRMING
  ONGOING
  FINISHED
  WALKOVER
  CANCELLED
}

model Round {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  tournamentId String @db.ObjectId

  index Int     @default(1)
  name  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches    Match[]
  tournament Tournament @relation(fields: [tournamentId], references: [id])
}

model Participant {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  role ParticipantRole @default(PLAYER)

  tournamentId String @db.ObjectId
  userId       String @db.ObjectId

  name     String
  nickname String

  status    ParticipantStatus
  confirmed Boolean           @default(false)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  teamMembers TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, userId])
}

enum ParticipantStatus {
  ACTIVE
  ELIMINATED
  RESERVED
  REPLACED
  SPECTATOR
}

enum ParticipantRole {
  PLAYER
  ADMIN
  MODERADOR
  JUIZ
  STREAMER
  AJUDANTE
}

type Webhook {
  listTeams   String?
  currentGame String?
  invite      String?
  winner      String?
}

model Tournament {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String @db.ObjectId

  webhook Webhook?

  preset      String? @default("custom")
  title       String
  description String
  prize       String

  startDate DateTime
  endType   EndType   @default(MANUAL)
  endDate   DateTime?

  format         Format           @default(SINGLE_ELIMINATION)
  gameMode       GameMode         @default(SABOTAGEM)
  statsType      StatsType        @default(MATCH)
  teamManagement TeamManagement   @default(RANDOM)
  status         TournamentStatus @default(CLOSED)

  swapTeam        Boolean @default(true)
  matchesPerMatch Int     @default(1)

  totalTeams       Int
  playersPerTeam   Int
  maxPlayers       Int
  maxRegistrations Int

  confirmationSystem Boolean @default(false)
  confirmationTime   Int     @default(5)

  hasSubstitutes   Boolean
  substitutesLimit Int

  broadcastPlatform BroadcastPlatform?
  broadcastUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants          Participant[]
  matches               Match[]
  teams                 Team[]
  rounds                Round[]
  tournamentRoleRequest TournamentRoleRequest[]
}

model TournamentRoleRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  requestedRole ParticipantRole
  status        RequestStatus   @default(PENDING)

  name     String
  nickname String

  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId String     @db.ObjectId

  @@unique([ownerId, tournamentId])
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DENIED
}

enum TournamentStatus {
  CLOSED
  OPEN
  SETTING_TEAM
  SETTING_MATCHES
  READY
  LIVE
  FINISHED
}

enum EndType {
  DATE
  MANUAL
}

enum Format {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  SWISS
}

enum GameMode {
  SABOTAGEM
  MATA_MATA
  PROCURADO
  ESCOLTA
  ELIMINAÇÃO
}

enum StatsType {
  ROUND
  MATCH
}

enum TeamManagement {
  RANDOM
  CLAN
}

enum BroadcastPlatform {
  TWITCH
  YOUTUBE
  NONE
}
