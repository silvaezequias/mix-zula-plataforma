// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type Player {
  id       String?
  nickname String
  clanId   String?
}

type Stat {
  kill    Int
  death   Int
  assists Int
  matchId String
}

model User {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  discordId String?
  name      String?
  email     String? @unique
  birthDate String?

  emailVerified DateTime?
  isOnboarded   Boolean   @default(false)

  image String?

  player       Player?
  generalStats Stat[]

  accounts    Account[]
  sessions    Session[]
  tournaments Tournament[]
}

model Account {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId

  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?

  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model Tournament {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String @db.ObjectId

  preset      String? @default("custom")
  title       String
  description String
  prize       String

  startDate DateTime
  endType   EndType   @default(MANUAL)
  endDate   DateTime?

  format         Format         @default(SINGLE_ELIMINATION)
  gameMode       GameMode       @default(SABOTAGEM)
  statsType      StatsType      @default(MATCH)
  teamManagement TeamManagement @default(RANDOM)

  swapTeam        Boolean @default(true)
  matchesPerMatch Int     @default(1)

  totalTeams       Int
  playersPerTeam   Int
  maxPlayers       Int
  maxRegistrations Int

  confirmationSystem Boolean @default(false)
  confirmationTime   Int     @default(5)

  hasSubstitutes   Boolean
  substitutesLimit Int

  broadcastPlatform BroadcastPlatform?
  broadcastUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EndType {
  DATE
  MANUAL
}

enum Format {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  SWISS
}

enum GameMode {
  SABOTAGEM
  MATA_MATA
  PROCURADO
  ESCOLTA
  ELIMINAÇÃO
}

enum StatsType {
  ROUND
  MATCH
}

enum TeamManagement {
  RANDOM
  CLAN
}

enum BroadcastPlatform {
  TWITCH
  YOUTUBE
  NONE
}
